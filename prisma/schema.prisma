>>>>>>> 7382218520c51f199422a1513e6c96252694c92f

  @@index([ownerId])
  @@index([visibility])
  @@index([createdAt])
}

model Deck {
  id         String     @id @default(cuid())
  ownerId    String
  name       String
  visibility Visibility @default(PUBLIC)
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  owner    User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  slots    DeckSlot[]
  battlesA Battle[]   @relation("BattleDeckA")
  battlesB Battle[]   @relation("BattleDeckB")
  wins     Battle[]   @relation("BattleDeckWinner")

  @@index([ownerId])
  @@index([visibility])
  @@index([createdAt])
}

model DeckSlot {
  id      String @id @default(cuid())
  deckId  String
  comboId String
  slot    Int

  deck  Deck  @relation(fields: [deckId], references: [id], onDelete: Cascade)
  combo Combo @relation(fields: [comboId], references: [id], onDelete: Restrict)

  @@unique([deckId, slot])
  @@unique([deckId, comboId])
  @@index([comboId])
}

model ComboStar {
  id        String   @id @default(cuid())
  comboId   String
  userId    String
  createdAt DateTime @default(now())

  combo Combo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([comboId, userId])
  @@index([comboId])
  @@index([userId])
  @@index([createdAt])
}

model ComboPut {
  id        String   @id @default(cuid())
  comboId   String
  userId    String
  createdAt DateTime @default(now())

  combo Combo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([comboId, userId])
  @@index([comboId])
  @@index([userId])
  @@index([createdAt])
}

model ComboComment {
  id        String   @id @default(cuid())
  comboId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  combo  Combo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([comboId, createdAt])
  @@index([authorId])
}

model VisitorActivity {
  id        String   @id @default(cuid())
  visitorId String   @unique
  userId    String?
  path      String
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([lastSeen])
  @@index([userId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String?
  kind       ReportKind
  status     ReportStatus @default(OPEN)
  title      String
  details    String
  path       String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  reporter User? @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([kind])
  @@index([createdAt])
}

model ComboPart {
  id      String   @id @default(cuid())
  comboId String
  partId  String
  role    PartType

  combo Combo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  part  Part  @relation(fields: [partId], references: [id], onDelete: Restrict)

  @@unique([comboId, role])
  @@index([partId])
}

model ComboPhoto {
  id         String     @id @default(cuid())
  comboId    String
  ownerId    String
  url        String
  fileName   String
  mimeType   String
  sizeBytes  Int
  visibility Visibility @default(PUBLIC)
  createdAt  DateTime   @default(now())

  combo Combo @relation(fields: [comboId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([visibility])
}

model Battle {
  id         String     @id @default(cuid())
  ownerId    String
  format     BattleFormat @default(ONE_V_ONE)
  comboAId   String?
  comboBId   String?
  winnerId   String?
  deckAId    String?
  deckBId    String?
  deckWinnerId String?
  visibility Visibility @default(PUBLIC)
  playedAt   DateTime   @default(now())
  notes      String?
  createdAt  DateTime   @default(now())

  owner  User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  comboA Combo? @relation("BattleComboA", fields: [comboAId], references: [id], onDelete: Restrict)
  comboB Combo? @relation("BattleComboB", fields: [comboBId], references: [id], onDelete: Restrict)
  winner Combo? @relation("BattleWinner", fields: [winnerId], references: [id], onDelete: Restrict)
  deckA Deck? @relation("BattleDeckA", fields: [deckAId], references: [id], onDelete: Restrict)
  deckB Deck? @relation("BattleDeckB", fields: [deckBId], references: [id], onDelete: Restrict)
  deckWinner Deck? @relation("BattleDeckWinner", fields: [deckWinnerId], references: [id], onDelete: Restrict)

  @@index([ownerId])
  @@index([format])
  @@index([visibility])
  @@index([comboAId])
  @@index([comboBId])
  @@index([winnerId])
  @@index([deckAId])
  @@index([deckBId])
  @@index([deckWinnerId])
  @@index([playedAt])
}
