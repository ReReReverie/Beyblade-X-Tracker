generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PartType {
  BLADE
  RATCHET
  BIT
}

enum Manufacturer {
  HASBRO
  TAKARA_TOMY
  FAKE
  UNKNOWN
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum Role {
  USER
  ADMIN
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ReportKind {
  BUG
  REQUEST
}

enum BattleFormat {
  ONE_V_ONE
  THREE_V_THREE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  username      String?   @unique
  role          Role      @default(USER)
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  parts    Part[]
  combos   Combo[]
  decks    Deck[]
  battles  Battle[]
  stars    ComboStar[]
  puts     ComboPut[]
  comments ComboComment[]
  reports  Report[]

  @@index([createdAt])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Part {
  id              String       @id @default(cuid())
  ownerId         String
  name            String
  type            PartType
  manufacturer    Manufacturer @default(UNKNOWN)
  weightGrams     Decimal      @db.Decimal(6, 2)
  conditionRating Decimal      @db.Decimal(3, 1)
  visibility      Visibility   @default(PUBLIC)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  photos     PartPhoto[]
  comboParts ComboPart[]

  @@index([ownerId, type])
  @@index([visibility])
  @@index([manufacturer])
  @@index([createdAt])
}

model PartPhoto {
  id         String     @id @default(cuid())
  partId     String
  ownerId    String
  url        String
  fileName   String
  mimeType   String
  sizeBytes  Int
  visibility Visibility @default(PUBLIC)
  createdAt  DateTime   @default(now())

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([visibility])
}

model Combo {
  id         String     @id @default(cuid())
  ownerId    String
  name       String
  visibility Visibility @default(PUBLIC)
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  owner      User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parts      ComboPart[]
  photos     ComboPhoto[]
  battlesA   Battle[]     @relation("BattleComboA")
  battlesB   Battle[]     @relation("BattleComboB")
  wins       Battle[]     @relation("BattleWinner")
  stars      ComboStar[]
